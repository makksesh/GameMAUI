<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="MobileApp.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:MobileApp.Converters">

    <Application.Resources>
        <ResourceDictionary>

            <!-- ═══════════════════════════════════
                 ЦВЕТА
            ═══════════════════════════════════ -->
            <!-- Градиент фона -->
            <Color x:Key="ColorBgDark">#B80D2231</Color>
            <Color x:Key="ColorBgMid">#B864226A</Color>
            <Color x:Key="ColorBgLight">#B8144161</Color>
            
            <!-- Primary UI -->
            <Color x:Key="ColorPrimary">#7C438D</Color>
            <Color x:Key="ColorPrimaryHover">#9B5DB0</Color>
            <Color x:Key="ColorPrimaryPressed">#3D1F4A</Color>
            
            <!-- Текст -->
            <Color x:Key="ColorTextPrimary">#FFFFFF</Color>
            <Color x:Key="ColorTextOnWhite">#7C438D</Color>
            <Color x:Key="ColorPlaceholder">#CCCCCC</Color>
            
            <!-- Поверхности -->
            <Color x:Key="ColorSurface">#FFFFFF</Color>
            
            <!-- Статусные -->
            <Color x:Key="ColorError">#FF6B6B</Color>
            <Color x:Key="ColorSuccess">#4CAF50</Color>
            <Style x:Key="DangerButton" TargetType="Button"
                   BasedOn="{StaticResource SecondaryButton}">
                    <Setter Property="TextColor" Value="{StaticResource ColorError}" />
            </Style>
            
            <!-- Legacy-алиасы (чтобы не ломать страницы, которые ещё не переписаны) -->
            <Color x:Key="ColorAccent">#7C438D</Color>
            <Color x:Key="ColorSecondary">#CCCCCC</Color>
            <Color x:Key="ColorBackgroundPrimary">#0D2231</Color>
            
            <!-- Старые ключи, но под новую тему -->
            <Color x:Key="ColorCurrency">#D4AF37</Color>        <!-- золото для валюты -->
            <Color x:Key="ColorHighlight">#9B5DB0</Color>       <!-- мягкий фиолет. highlight -->
            <Color x:Key="ColorBorder">#7C438D</Color>          <!-- фиолетовые бордеры -->
            
            <!-- ═══════════════════════════════════
                 КОНВЕРТЕРЫ
            ═══════════════════════════════════ -->
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <converters:EqualConverter x:Key="EqualConverter" />
            <converters:NotEqualConverter x:Key="NotEqualConverter" />
            <converters:BoolToLayoutOptionsConverter x:Key="BoolToLayoutOptionsConverter" />

            <!-- ═══════════════════════════════════
                 СТИЛИ СТРАНИЦ
            ═══════════════════════════════════ -->
            <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
                <Setter Property="BackgroundColor"
                        Value="{StaticResource ColorBackgroundPrimary}" />
            </Style>

            <Style TargetType="Shell" ApplyToDerivedTypes="True">
                <Setter Property="Shell.BackgroundColor"
                        Value="Transparent" />
                <Setter Property="Shell.ForegroundColor"
                        Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="Shell.TitleColor"
                        Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="Shell.TabBarBackgroundColor"
                        Value="Transparent"/>
                <Setter Property="Shell.TabBarForegroundColor"
                        Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="Shell.TabBarTitleColor"
                        Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="Shell.TabBarUnselectedColor"
                        Value="{StaticResource ColorSecondary}" />
                <Setter Property="Shell.NavBarHasShadow" Value="False" />
            </Style>

            <!-- ═══════════════════════════════════
                 СТИЛИ ТЕКСТА
            ═══════════════════════════════════ -->
            <Style x:Key="TitleLabel" TargetType="Label">
                <Setter Property="TextColor"
                        Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="BodyLabel" TargetType="Label">
                <Setter Property="TextColor"
                        Value="{StaticResource ColorTextPrimary}" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="CaptionLabel" TargetType="Label">
                <Setter Property="TextColor"
                        Value="{StaticResource ColorSecondary}" />
                <Setter Property="FontSize" Value="12" />
            </Style>
            
            <!-- <Style TargetType="Label"> -->
            <!--     <Setter Property="TextColor" -->
            <!--             Value="{StaticResource ColorTextPrimary}" /> -->
            <!-- </Style> -->

            <!-- ═══════════════════════════════════
                 СТИЛИ КНОПОК
            ═══════════════════════════════════ -->
            
            <!-- Фиолетовая кнопка — текст белый -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                    <Setter Property="BackgroundColor" Value="{StaticResource ColorPrimary}" />
                    <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
                    <Setter Property="CornerRadius" Value="15" />
                    <Setter Property="BorderWidth" Value="0" />
                    <Setter Property="Padding" Value="16,14" />
                    <Setter Property="FontAttributes" Value="Bold" />
                    <Setter Property="FontSize" Value="15" />
            </Style>

            <!-- Белая кнопка — текст #7C438D -->
            <Style x:Key="SecondaryButton" TargetType="Button">
                    <Setter Property="BackgroundColor" Value="{StaticResource ColorTextPrimary}" />
                    <Setter Property="TextColor" Value="{StaticResource ColorTextOnWhite}" />
                    <Setter Property="CornerRadius" Value="15" />
                    <Setter Property="BorderWidth" Value="0" />
                    <Setter Property="Padding" Value="16,14" />
                    <Setter Property="FontAttributes" Value="Bold" />
                    <Setter Property="FontSize" Value="15" />
            </Style>

            <!-- ═══════════════════════════════════
                 СТИЛИ ПОЛЕЙ ВВОДА
            ═══════════════════════════════════ -->
            <Style x:Key="InputBorder" TargetType="Border">
                    <Setter Property="Stroke" Value="White" />
                    <Setter Property="StrokeThickness" Value="1" />
                    <Setter Property="BackgroundColor" Value="Transparent" />
                    <Setter Property="Margin" Value="0,0,0,14" />
                    <Setter Property="StrokeShape">
                            <Setter.Value>
                                    <RoundRectangle CornerRadius="10" />
                            </Setter.Value>
                    </Setter>
            </Style>

            <Style x:Key="InputEntry" TargetType="Entry">
                    <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
                    <Setter Property="PlaceholderColor" Value="{StaticResource ColorPlaceholder}" />
                    <Setter Property="BackgroundColor" Value="Transparent" />
                    <Setter Property="Margin" Value="8,0" />
            </Style>

            <!-- Глобальные стили элементов ввода -->
            <Style TargetType="Entry">
                    <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
                    <Setter Property="PlaceholderColor" Value="{StaticResource ColorPlaceholder}" />
                    <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>

            <Style TargetType="Editor">
                    <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
                    <Setter Property="PlaceholderColor" Value="{StaticResource ColorPlaceholder}" />
                    <Setter Property="BackgroundColor" Value="{StaticResource ColorSurface}" />
            </Style>

            <Style TargetType="Picker">
                    <Setter Property="TextColor" Value="{StaticResource ColorTextPrimary}" />
                    <Setter Property="TitleColor" Value="{StaticResource ColorPlaceholder}" />
                    <Setter Property="BackgroundColor" Value="{StaticResource ColorSurface}" />
            </Style>
            
            <!-- ═══════════════════════════════════
                 СТИЛИ ЯЧЕЕК ИНВЕНТАРЯ
            ═══════════════════════════════════ -->
            <Style x:Key="SlotBorder" TargetType="Border">
                    <Setter Property="BackgroundColor" Value="#80F06B6F" /> 
                    <Setter Property="Stroke" Value="#FFC15A" />
                    <Setter Property="StrokeThickness" Value="2" />
                    <Setter Property="StrokeShape" Value="RoundRectangle 25" />
                    <Setter Property="Padding" Value="6" />
                    <Setter Property="WidthRequest" Value="82" />
                    <Setter Property="HeightRequest" Value="82" />
                    <Setter Property="HorizontalOptions" Value="Center" />
            </Style>

            <!-- Стиль ячейки инвентаря (нижняя сетка 32 слота) -->
            <Style x:Key="InventorySlotBorder" TargetType="Border">
                    <Setter Property="BackgroundColor" Value="#80F06B6F" />
                    <Setter Property="Stroke" Value="#FFC15A" />
                    <Setter Property="StrokeThickness" Value="2" />
                    <Setter Property="StrokeShape" Value="RoundRectangle 25" />
                    <Setter Property="Padding" Value="4" />
                    <Setter Property="WidthRequest" Value="72" />
                    <Setter Property="HeightRequest" Value="72" />
                    <Setter Property="HorizontalOptions" Value="Center" />
                    <Setter Property="Margin" Value="3" />
            </Style>


        </ResourceDictionary>
    </Application.Resources>
</Application>