<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileApp.Views.Profile.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="True"
    Title="Профиль">

    <!-- ═══ ГРАДИЕНТНЫЙ ФОН ═══ -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B80D2231" Offset="0.20" />
            <GradientStop Color="#B864226A" Offset="0.50" />
            <GradientStop Color="#B8144161" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>
    
    <ContentPage.Resources>
        
        <ResourceDictionary>

            <!-- ═══ СТИЛЬ КНОПКИ "АКТИВНАЯ" (Помощь / Изменить пароль / Локально) ═══ -->
            <Style x:Key="GradientActiveButton" TargetType="Button">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="22" />
                <Setter Property="BorderColor" Value="White" />
                <Setter Property="BorderWidth" Value="1.5" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Padding" Value="0,12" />
                <!-- 3D-эффект через Shadow -->
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#BC32D2" Offset="0,4" Radius="6" Opacity="0.55" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ СТИЛЬ КНОПКИ "ОБЛАКО" (неактивная, 50% прозрачности) ═══ -->
            <Style x:Key="GradientCloudButton" TargetType="Button"
                   BasedOn="{StaticResource GradientActiveButton}">
                <Setter Property="Opacity" Value="0.5" />
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">
            <!-- ───── Разделитель ───── -->
            <BoxView HeightRequest="1"
                     Color="#FFFFFF"
                     Margin="0,4" />
            <!-- ───── 1. Данные пользователя ───── -->
            <Frame BackgroundColor="Transparent"
                   BorderColor="Transparent"
                   CornerRadius="12"
                   Padding="16"
                   HasShadow="False">
                <VerticalStackLayout Spacing="10">
                    <Label>
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="login:  " TextColor="#ACC9E7" />
                                <Span Text="{Binding Username}"
                                      TextColor="White"
                                      FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label>
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="email:  " TextColor="#ACC9E7" />
                                <Span Text="{Binding Email}"
                                      TextColor="White" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
            </Frame>
            <!-- ───── Разделитель ───── -->
            <BoxView HeightRequest="1"
                     Color="#FFFFFF"
                     Margin="0,4" />

            <!-- ───── Кнопки Помощь / Изменить пароль ───── -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <Button Grid.Column="0"
                        Text="Помощь"
                        Command="{Binding GoToSupportCommand}"
                        Style="{StaticResource SecondaryButton}" />

                <Button Grid.Column="1"
                        Text="Изменить пароль"
                        Command="{Binding GoToChangePasswordCommand}"
                        Style="{StaticResource SecondaryButton}" />

            </Grid>


            <!-- ───── 2. Громкость музыки ───── -->
            <Label Text="Громкость музыки"
                   TextColor="White"
                   FontSize="15" />
            <Slider Minimum="0" Maximum="1"
                    Value="{Binding MusicVolume}"
                    ThumbColor="White"
                    MinimumTrackColor="#FFF5E1"
                    MaximumTrackColor="#787878" />

            <!-- ───── 3. Громкость звуков ───── -->
            <Label Text="Громкость звуков"
                   TextColor="White"
                   FontSize="15" />
            <Slider Minimum="0" Maximum="1"
                    Value="{Binding SfxVolume}"
                    ThumbColor="White"
                    MinimumTrackColor="#FFF5E1"
                    MaximumTrackColor="#787878"  />

            <!-- ───── 4. Место сохранения ───── -->
            <Label Text="Место сохранения игровых данных"
                   TextColor="White"
                   FontSize="15" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <!-- Локально -->
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource ColorTextPrimary}"
                        Stroke="{StaticResource ColorTextPrimary}"
                        StrokeThickness="1.5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="*, 36"
                          Padding="14,0,10,0"
                          Opacity="{Binding LocalButtonOpacity}">
                        <Label Grid.Column="0"
                               Text="Локально"
                               TextColor="{StaticResource ColorTextOnWhite}"
                               FontAttributes="Bold"
                               FontSize="15"
                               VerticalOptions="Center" />
                        <Image Grid.Column="1"
                               Source="icon_local.png"
                               HeightRequest="44"
                               WidthRequest="22"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding SelectStorageCommand}"
                            CommandParameter="Local" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Облако -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource ColorTextPrimary}"
                        Stroke="{StaticResource ColorTextPrimary}"
                        StrokeThickness="1.5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>

                    <Grid ColumnDefinitions="*, 36"
                          Padding="14,0,10,0"
                          Opacity="{Binding CloudButtonOpacity}">
                        <Label Grid.Column="0"
                               Text="Облако"
                               TextColor="{StaticResource ColorTextOnWhite}"
                               FontAttributes="Bold"
                               FontSize="15"
                               VerticalOptions="Center" />
                        <Image Grid.Column="1"
                               Source="icon_cloud.png"
                               HeightRequest="44"
                               WidthRequest="22"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding SelectStorageCommand}"
                            CommandParameter="Cloud" />
                    </Border.GestureRecognizers>
                </Border>


            </Grid>


            <!-- ───── 5. Уведомления ───── -->
            <Grid ColumnDefinitions="*, Auto">
                <Label Grid.Column="0"
                       Text="Уведомления"
                       TextColor="White"
                       FontSize="15"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding NotificationsEnabled}"
                        OnColor="#ACC9E7"
                        ThumbColor="White"
                        HorizontalOptions="End" />
            </Grid>

            <!-- ───── Разделитель ───── -->
            <BoxView HeightRequest="1"
                     Color="#FFFFFF"
                     Margin="0,4" />

            <!-- ───── Выйти ───── -->
            <Button Text="Выйти"
                    Command="{Binding LogoutCommand}"
                    Style="{StaticResource DangerButton}"
                    Margin="0,30,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
