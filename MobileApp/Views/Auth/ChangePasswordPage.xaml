<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileApp.Views.Auth.ChangePasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="">

    <!-- ═══ ГРАДИЕНТНЫЙ ФОН ═══ -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B80D2231" Offset="0.20" />
            <GradientStop Color="#B864226A" Offset="0.50" />
            <GradientStop Color="#B8144161" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout
            Padding="24"
            Spacing="0"
            VerticalOptions="Center">

            <!-- ═══ ЗАГОЛОВОК ═══ -->
            <Label
                Text="Изменение пароля"
                TextColor="White"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Start"
                Margin="0,40,0,40" />

            <!-- ═══ ТЕКУЩИЙ ПАРОЛЬ ═══ -->
            <Border
                Stroke="White"
                StrokeThickness="1"
                BackgroundColor="Transparent"
                Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Entry
                    Placeholder="Введите текущий пароль..."
                    PlaceholderColor="#CCCCCC"
                    Text="{Binding CurrentPassword}"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    IsPassword="True"
                    ReturnType="Next"
                    Margin="8,0" />
            </Border>

            <!-- ═══ НОВЫЙ ПАРОЛЬ ═══ -->
            <Border
                Stroke="White"
                StrokeThickness="1"
                BackgroundColor="Transparent"
                Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Entry
                    Placeholder="Введите новый пароль..."
                    PlaceholderColor="#CCCCCC"
                    Text="{Binding NewPassword}"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    IsPassword="True"
                    ReturnType="Next"
                    Margin="8,0" />
            </Border>

            <!-- ═══ ПОДТВЕРЖДЕНИЕ ПАРОЛЯ ═══ -->
            <Border
                Stroke="White"
                StrokeThickness="1"
                BackgroundColor="Transparent"
                Margin="0,0,0,24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Entry
                    Placeholder="Повторите новый пароль..."
                    PlaceholderColor="#CCCCCC"
                    Text="{Binding ConfirmPassword}"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    IsPassword="True"
                    ReturnType="Done"
                    Margin="8,0" />
            </Border>

            <!-- ═══ ОШИБКА ═══ -->
            <Label
                Text="{Binding ErrorMessage}"
                TextColor="#FF6B6B"
                IsVisible="{Binding HasError}"
                HorizontalOptions="Center"
                Margin="0,0,0,12" />

            <!-- ═══ ИНДИКАТОР ЗАГРУЗКИ ═══ -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="White"
                HorizontalOptions="Center"
                Margin="0,0,0,12" />

            <!-- ═══ КНОПКИ ═══ -->
            <Grid ColumnDefinitions="*,16,*" Margin="0,0,0,32">

                <!-- Отмена (белая кнопка, текст #7C438D) -->
                <Border
                    Grid.Column="0"
                    BackgroundColor="White"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Grid>
                        <Button
                            Text="Отмена"
                            TextColor="#7C438D"
                            BackgroundColor="Transparent"
                            Command="{Binding CancelCommand}"
                            FontAttributes="Bold"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Padding="0" />
                        <!-- Иконка справа -->
                        <Image
                            Source="icon_cancel.png"
                            HeightRequest="18"
                            WidthRequest="18"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            Margin="0,0,14,0" />
                    </Grid>
                </Border>

                <!-- Изменить (фиолетовая кнопка #7C438D, текст белый) -->
                <Border
                    Grid.Column="2"
                    BackgroundColor="#7C438D"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Grid>
                        <Button
                            Text="Изменить"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            Command="{Binding SaveCommand}"
                            FontAttributes="Bold"
                            HorizontalOptions="Fill"
                            VerticalOptions="Fill"
                            Padding="0" />
                        <!-- Иконка справа -->
                        <Image
                            Source="icon_save.png"
                            HeightRequest="18"
                            WidthRequest="18"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            Margin="0,0,14,0" />
                    </Grid>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
