<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileApp.Views.Auth.ChangePasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Изменить пароль">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14" VerticalOptions="Center">

            <Label
                Text="Смена пароля"
                Style="{StaticResource TitleLabel}"
                HorizontalOptions="Center"
                Margin="0,0,0,16" />

            <!-- Текущий пароль -->
            <Label Text="Текущий пароль"
                   TextColor="{StaticResource ColorSecondary}"
                   FontSize="12" />
            <Entry
                Placeholder="Введите текущий пароль"
                PlaceholderColor="{StaticResource ColorSecondary}"
                Text="{Binding CurrentPassword}"
                TextColor="{StaticResource ColorTextPrimary}"
                BackgroundColor="#3D2416"
                IsPassword="True"
                ReturnType="Next" />

            <!-- Новый пароль -->
            <Label Text="Новый пароль"
                   TextColor="{StaticResource ColorSecondary}"
                   FontSize="12" />
            <Entry
                Placeholder="Введите новый пароль"
                PlaceholderColor="{StaticResource ColorSecondary}"
                Text="{Binding NewPassword}"
                TextColor="{StaticResource ColorTextPrimary}"
                BackgroundColor="#3D2416"
                IsPassword="True"
                ReturnType="Next" />

            <!-- Подтверждение нового пароля -->
            <Label Text="Подтвердите новый пароль"
                   TextColor="{StaticResource ColorSecondary}"
                   FontSize="12" />
            <Entry
                Placeholder="Повторите новый пароль"
                PlaceholderColor="{StaticResource ColorSecondary}"
                Text="{Binding ConfirmPassword}"
                TextColor="{StaticResource ColorTextPrimary}"
                BackgroundColor="#3D2416"
                IsPassword="True"
                ReturnType="Done" />

            <!-- Ошибка -->
            <Label
                Text="{Binding ErrorMessage}"
                TextColor="#FF6B6B"
                IsVisible="{Binding HasError}"
                HorizontalOptions="Center" />

            <!-- Кнопка сохранить -->
            <Button
                Text="Сохранить"
                Command="{Binding SaveCommand}"
                Style="{StaticResource PrimaryButton}"
                Margin="0,8,0,0" />

            <!-- Индикатор загрузки -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource ColorAccent}"
                HorizontalOptions="Center" />

            <!-- Кнопка назад -->
            <Button
                Text="Отмена"
                Command="{Binding CancelCommand}"
                Style="{StaticResource SecondaryButton}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
