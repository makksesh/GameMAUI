<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileApp.Views.Inventory.InventoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MobileApp.ViewModels.Inventory"
    xmlns:inv="clr-namespace:MobileApp.Models.Inventory"
    x:DataType="vm:InventoryViewModel"
    Title="Инвентарь">

    <!-- ═══ ГРАДИЕНТНЫЙ ФОН ═══ -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B80D2231" Offset="0.20" />
            <GradientStop Color="#B864226A" Offset="0.50" />
            <GradientStop Color="#B8144161" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <!-- ── Слот экипировки ── -->
        <Style x:Key="EquipSlot" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#80F06B6F" />
            <Setter Property="Stroke" Value="#FFC15A" />
            <Setter Property="StrokeThickness" Value="1.8" />
            <Setter Property="StrokeShape" Value="RoundRectangle 25" />
            <Setter Property="WidthRequest" Value="76" />
            <Setter Property="HeightRequest" Value="76" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
        <!-- ── Ячейка общего инвентаря ── -->
        <Style x:Key="InvCell" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#80F06B6F" />
            <Setter Property="Stroke" Value="#FFC15A" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="StrokeShape" Value="RoundRectangle 25" />
            <Setter Property="WidthRequest" Value="70" />
            <Setter Property="HeightRequest" Value="70" />
            <Setter Property="Margin" Value="4" />
        </Style>
        <Style x:Key="SlotHint" TargetType="Label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextColor" Value="#C4A67C" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Style x:Key="ItemInSlot" TargetType="Label">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="TextColor" Value="#FFF5E1" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
            <Setter Property="MaxLines" Value="3" />
            <Setter Property="LineBreakMode" Value="WordWrap" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="14,10" RowDefinitions="Auto,Auto,*" RowSpacing="0">

            <!-- ══════════════════════════════════════════════════
                 БЛОК 1: Характеристики (слева) + Слоты (справа)
                 ══════════════════════════════════════════════════ -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="110,*"
                  ColumnSpacing="8"
                  Margin="0,0,0,16">

                <!-- ── ХАРАКТЕРИСТИКИ ── -->
                <VerticalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Start" Margin="0,8,0,0">

                    <!-- Кнопка Улучшить -->
                    <Button Text="Улучшить"
                            Command="{Binding GoToUpgradeCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#FFC15A"
                            BorderColor="#FFC15A"
                            BorderWidth="1"
                            CornerRadius="10"
                            FontSize="11"
                            Padding="6,4"
                            HorizontalOptions="Fill"
                            Margin="0,0,0,4" />

                    <!-- HP -->
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Image Source="icon_health.png" WidthRequest="32" HeightRequest="32" VerticalOptions="Center"/>
                        <Label Text="{Binding Character.Health, FallbackValue='—'}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#FFF5E1" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Защита -->
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Image Source="icon_defense.png" WidthRequest="32" HeightRequest="32" VerticalOptions="Center"/>
                        <Label Text="{Binding Character.Armor, FallbackValue='—'}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#FFF5E1" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Урон -->
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Image Source="icon_damage.png" WidthRequest="32" HeightRequest="32" VerticalOptions="Center"/>
                        <Label Text="{Binding Character.Damage, FallbackValue='—'}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#FFF5E1" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Мана -->
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Image Source="icon_mana.png" WidthRequest="32" HeightRequest="32" VerticalOptions="Center"/>
                        <Label Text="{Binding Character.Mana, FallbackValue='—'}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#FFF5E1" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>

                <!-- ── СЛОТЫ ЭКИПИРОВКИ ── -->
                <!--
                    Макет (по Figma):
                    [ Кольцо1 ]  [ пусто  ]  [ Шлем   ]
                    [ Кольцо2 ]  [ пусто  ]  [ Броня  ]
                    [ пусто   ]  [ пусто  ]  [ Ботинки]
                -->
                <Grid Grid.Column="1"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,*,*"
                      RowSpacing="10"
                      ColumnSpacing="8">

                    <!-- Ряд 1: Кольцо1 | пусто | Шлем -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                        <Border Style="{StaticResource EquipSlot}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding UnequipCommand}"
                                                      CommandParameter="{Binding RingSlot1.Id}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding RingSlot1.ItemName, TargetNullValue='·'}"
                                   Style="{StaticResource ItemInSlot}"
                                   VerticalOptions="Center" Margin="4" />
                        </Border>
                        <Label Text="Кольцо 1" Style="{StaticResource SlotHint}" />
                    </VerticalStackLayout>

                    <!-- пусто (центр ряд 1) -->
                    <BoxView Grid.Row="0" Grid.Column="1" IsVisible="False" />

                    <VerticalStackLayout Grid.Row="0" Grid.Column="2" Spacing="4">
                        <Border Style="{StaticResource EquipSlot}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding UnequipCommand}"
                                                      CommandParameter="{Binding HelmetSlot.Id}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding HelmetSlot.ItemName, TargetNullValue='·'}"
                                   Style="{StaticResource ItemInSlot}"
                                   VerticalOptions="Center" Margin="4" />
                        </Border>
                        <Label Text="Шлем" Style="{StaticResource SlotHint}" />
                    </VerticalStackLayout>

                    <!-- Ряд 2: Кольцо2 | пусто | Броня -->
                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                        <Border Style="{StaticResource EquipSlot}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding UnequipCommand}"
                                                      CommandParameter="{Binding RingSlot2.Id}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding RingSlot2.ItemName, TargetNullValue='·'}"
                                   Style="{StaticResource ItemInSlot}"
                                   VerticalOptions="Center" Margin="4" />
                        </Border>
                        <Label Text="Кольцо 2" Style="{StaticResource SlotHint}" />
                    </VerticalStackLayout>

                    <!-- пусто (центр ряд 2) -->
                    <BoxView Grid.Row="1" Grid.Column="1" IsVisible="False" />

                    <VerticalStackLayout Grid.Row="1" Grid.Column="2" Spacing="4">
                        <Border Style="{StaticResource EquipSlot}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding UnequipCommand}"
                                                      CommandParameter="{Binding ArmorSlot.Id}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding ArmorSlot.ItemName, TargetNullValue='·'}"
                                   Style="{StaticResource ItemInSlot}"
                                   VerticalOptions="Center" Margin="4" />
                        </Border>
                        <Label Text="Броня" Style="{StaticResource SlotHint}" />
                    </VerticalStackLayout>

                    <!-- Ряд 3: пусто | пусто | Ботинки -->
                    <BoxView Grid.Row="2" Grid.Column="0" IsVisible="False" />
                    <BoxView Grid.Row="2" Grid.Column="1" IsVisible="False" />

                    <VerticalStackLayout Grid.Row="2" Grid.Column="2" Spacing="4">
                        <Border Style="{StaticResource EquipSlot}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding UnequipCommand}"
                                                      CommandParameter="{Binding BootsSlot.Id}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding BootsSlot.ItemName, TargetNullValue='·'}"
                                   Style="{StaticResource ItemInSlot}"
                                   VerticalOptions="Center" Margin="4" />
                        </Border>
                        <Label Text="Ботинки" Style="{StaticResource SlotHint}" />
                    </VerticalStackLayout>

                </Grid>
            </Grid>

            <!-- ══════════════════════════════════════════════════
                 БЛОК 2: Слоты оружия — 3 штуки в ряд по центру
                 ══════════════════════════════════════════════════ -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="8"
                  Margin="0,0,0,16">

                <!-- Weapon Slot 1 -->
                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <Border Style="{StaticResource EquipSlot}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding UnequipCommand}"
                                                  CommandParameter="{Binding WeaponSlot.Id}" />
                        </Border.GestureRecognizers>
                        <Label Text="{Binding WeaponSlot.ItemName, TargetNullValue='·'}"
                               Style="{StaticResource ItemInSlot}"
                               VerticalOptions="Center" Margin="4" />
                    </Border>
                    <Label Text="Слот 1" Style="{StaticResource SlotHint}" />
                </VerticalStackLayout>

                <!-- Weapon Slot 2 (пустой — доп. оружие, расширение) -->
                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <Border Style="{StaticResource EquipSlot}">
                        <Label Text="·" Style="{StaticResource ItemInSlot}" VerticalOptions="Center" />
                    </Border>
                    <Label Text="Слот 2" Style="{StaticResource SlotHint}" />
                </VerticalStackLayout>

                <!-- Weapon Slot 3 (пустой) -->
                <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                    <Border Style="{StaticResource EquipSlot}">
                        <Label Text="·" Style="{StaticResource ItemInSlot}" VerticalOptions="Center" />
                    </Border>
                    <Label Text="Слот 3" Style="{StaticResource SlotHint}" />
                </VerticalStackLayout>

            </Grid>

            <!-- ══════════════════════════════════════════════════
                 БЛОК 3: Инвентарь 32 ячейки (8 колонок × 4 ряда)
                 ══════════════════════════════════════════════════ -->
            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding InventorySlots}"
                            SelectionMode="None"
                            HorizontalOptions="Fill">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="4" HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="inv:InventorySlot">
                        <Border Style="{StaticResource InvCell}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EquipCommand}"
                                    CommandParameter="{Binding Item.Id}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2" Padding="4">
                                <Label Text="{Binding Item.ItemName}"
                                       Style="{StaticResource ItemInSlot}"
                                       IsVisible="{Binding HasItem}" />
                                <Label Text="{Binding Item.Rarity}"
                                       FontSize="8"
                                       TextColor="#D4AF37"
                                       HorizontalOptions="Center"
                                       IsVisible="{Binding HasItem}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </ScrollView>
</ContentPage>
