<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileApp.Views.Inventory.InventoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Инвентарь">

    <CollectionView ItemsSource="{Binding Items}" Margin="16">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame BackgroundColor="#3D2416"
                       BorderColor="{StaticResource ColorBorder}"
                       CornerRadius="10"
                       Margin="0,4"
                       Padding="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">

                            <!-- Название + редкость -->
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding ItemName}"
                                       TextColor="{StaticResource ColorTextPrimary}"
                                       FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding Rarity}"
                                       TextColor="{StaticResource ColorCurrency}"
                                       FontSize="11"
                                       BackgroundColor="#2C1810"
                                       Padding="4,2" />
                            </HorizontalStackLayout>

                            <!-- Тип и количество -->
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="{Binding ItemType}"
                                       TextColor="{StaticResource ColorSecondary}"
                                       FontSize="12" />
                                <Label TextColor="{StaticResource ColorSecondary}" FontSize="12">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="x" TextColor="{StaticResource ColorSecondary}" FontSize="12" />
                                            <Span Text="{Binding Quantity}" TextColor="{StaticResource ColorTextPrimary}" FontSize="12" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>

                            <!-- Цена -->
                            <Label FontSize="11">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Цена: " TextColor="{StaticResource ColorSecondary}" FontSize="11" />
                                        <Span Text="{Binding BasePrice, StringFormat='{0:F0} G'}"
                                              TextColor="{StaticResource ColorCurrency}" FontSize="11" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                        </VerticalStackLayout>

                        <!-- Кнопка экипировки -->
                        <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                            <Button Text="Надеть"
                                    IsVisible="{Binding IsEquipped, Converter={StaticResource InvertBoolConverter}}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EquipCommand}"
                                    CommandParameter="{Binding Id}"
                                    Style="{StaticResource PrimaryButton}"
                                    FontSize="12" Padding="10,6" />
                            <Button Text="Снять"
                                    IsVisible="{Binding IsEquipped}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UnequipCommand}"
                                    CommandParameter="{Binding Id}"
                                    Style="{StaticResource SecondaryButton}"
                                    FontSize="12" Padding="10,6" />
                        </VerticalStackLayout>

                    </Grid>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
