<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.Views.Support.ModeratorSupportPage"
             Title="Панель модератора">

    <VerticalStackLayout Padding="16" Spacing="12">

        <Picker Title="Статус тикетов"
                ItemsSource="{Binding StatusOptions}"
                SelectedItem="{Binding SelectedStatus}" />

        <Label Text="{Binding ErrorMessage}"
               TextColor="Red" />

        <CollectionView ItemsSource="{Binding Tickets}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,6"
                           Padding="12"
                           BackgroundColor="{StaticResource ColorSurface}"
                           BorderColor="{StaticResource ColorBorder}"
                           CornerRadius="8">

                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding Subject}"
                                   FontAttributes="Bold"
                                   Style="{StaticResource BodyLabel}" />

                            <Label Text="{Binding AuthorUsername, StringFormat='👤 {0}'}"
                                   Style="{StaticResource CaptionLabel}" />

                            <Label Text="{Binding Message}"
                                   Style="{StaticResource BodyLabel}" />

                            <Label Text="{Binding Status, StringFormat='Статус: {0}'}"
                                   Style="{StaticResource CaptionLabel}" />

                            <Label Text="{Binding Resolution, StringFormat='Ответ: {0}'}"
                                   Style="{StaticResource CaptionLabel}" />

                            <HorizontalStackLayout Spacing="8">
                                <Button Text="Взять в работу"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                          Path=BindingContext.AssignCommand}"
                                        CommandParameter="{Binding Id}" />

                                <Button Text="Открыть чат"
                                        Style="{StaticResource SecondaryButton}"
                                        Clicked="OnOpenChatClicked"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>

                            <Entry Text="{Binding ResolutionInput}"
                                   Placeholder="Введите ответ пользователю..." />

                            <Button Text="Закрыть тикет"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.ResolveCommand}"
                                    CommandParameter="{Binding Id}" />

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>
