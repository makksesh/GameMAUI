<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MobileApp.Views.Character.CharacterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MobileApp.ViewModels.Character"
    xmlns:inv="clr-namespace:MobileApp.Models"
    xmlns:inventory="clr-namespace:MobileApp.Models.Inventory"
    x:DataType="vm:CharacterViewModel"
    Title="Персонаж"
    Shell.NavBarIsVisible="True">

    <!-- Фон градиент -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B80D2231" Offset="0.20" />
            <GradientStop Color="#B864226A" Offset="0.50" />
            <GradientStop Color="#B8144161" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <Style x:Key="SlotCaption" TargetType="Label">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextColor" Value="{StaticResource ColorSecondary}" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="RarityLabel" TargetType="Label">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="TextColor" Value="{StaticResource ColorHighlight}" />
            <Setter Property="HorizontalOptions" Value="Center" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{StaticResource ColorSecondary}" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>
        <Style x:Key="StatIcon" TargetType="Image">
            <Setter Property="WidthRequest" Value="24" />
            <Setter Property="HeightRequest" Value="24" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <Grid RowDefinitions="Auto,*" Padding="12,16,12,16">

            <!-- ══ Нет персонажа ══ -->
            <VerticalStackLayout
                Grid.Row="0"
                IsVisible="{Binding HasCharacter, Converter={StaticResource InvertBoolConverter}}"
                Spacing="16"
                VerticalOptions="Center"
                HorizontalOptions="Center">
                <Label Text="У вас нет персонажа"
                       Style="{StaticResource TitleLabel}"
                       HorizontalOptions="Center" />
                <Button Text="Создать персонажа"
                        Command="{Binding CreateCommand}"
                        Style="{StaticResource PrimaryButton}" />
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource ColorAccent}" />
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#FF6B6B"
                       IsVisible="{Binding HasError}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- ══ Есть персонаж ══ -->
            <VerticalStackLayout
                Grid.Row="1"
                IsVisible="{Binding HasCharacter}"
                Spacing="0">

                <!-- Имя + уровень -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="{Binding Character.Name}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource ColorTextPrimary}" />
                        <Label FontSize="13" TextColor="{StaticResource ColorAccent}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Ур. " TextColor="{StaticResource ColorSecondary}" />
                                    <Span Text="{Binding Character.Level}"
                                          TextColor="{StaticResource ColorAccent}"
                                          FontAttributes="Bold" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                    <!-- Баланс -->
                    <Label Grid.Column="1"
                           FontSize="14"
                           VerticalOptions="Center"
                           TextColor="{StaticResource ColorCurrency}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding Character.Balance, StringFormat='{0:F0}'}"
                                      TextColor="{StaticResource ColorCurrency}"
                                      FontAttributes="Bold" />
                                <Span Text=" G" TextColor="{StaticResource ColorSecondary}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Grid>

                <!-- XP Bar -->
                <ProgressBar
                    Progress="{Binding Character.Experience}"
                    ProgressColor="{StaticResource ColorAccent}"
                    BackgroundColor="{StaticResource ColorSurface}"
                    Margin="0,0,0,12" />

                <!-- ══════════════════════════════════ -->
                <!-- ОСНОВНОЙ LAYOUT: стат | кольца | броня -->
                <!-- ══════════════════════════════════ -->
                <Grid ColumnDefinitions="110,*,*" ColumnSpacing="10" Margin="0,0,0,8">

                    <!-- ═══ КОЛОНКА 0: характеристики ═══ -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">

                        <!-- Кнопка "Улучшить" -->
                        <Button Text="Улучшить"
                                Command="{Binding GoToUpgradeCommand}"
                                Style="{StaticResource SecondaryButton}"
                                FontSize="12"
                                Padding="8,5"
                                Margin="0,0,0,6" />

                        <!-- HP -->
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Image Source="icon_health.png" Style="{StaticResource StatIcon}" />
                            <Label Text="{Binding Character.Health}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#FF6B6B"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!-- Armor -->
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Image Source="icon_armor.png" Style="{StaticResource StatIcon}" />
                            <Label Text="{Binding Character.Armor}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorHighlight}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!-- Damage -->
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Image Source="icon_damage.png" Style="{StaticResource StatIcon}" />
                            <Label Text="{Binding Character.Damage}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{StaticResource ColorAccent}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!-- Mana -->
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Image Source="icon_mana.png" Style="{StaticResource StatIcon}" />
                            <Label Text="{Binding Character.Mana}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#6B9FFF"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                    <!-- ═══ КОЛОНКА 1: Кольца (сверху вниз, по центру) ═══ -->
                    <VerticalStackLayout Grid.Column="1" Spacing="8"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">

                        <!-- Кольцо 1 -->
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Border Style="{StaticResource SlotBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding UnequipCommand}"
                                        CommandParameter="{Binding RingSlot1.Id}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                    <Image Source="icon_ring.png"
                                           WidthRequest="24" HeightRequest="24"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding RingSlot1.IsEquipped}" />
                                    <Label Text="{Binding RingSlot1.ItemName, TargetNullValue=''}"
                                           FontSize="9"
                                           TextColor="{StaticResource ColorTextPrimary}"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           MaxLines="2" LineBreakMode="WordWrap" />
                                    <Label Text="{Binding RingSlot1.Rarity}"
                                           Style="{StaticResource RarityLabel}"
                                           IsVisible="{Binding RingSlot1.IsEquipped}" />
                                </VerticalStackLayout>
                            </Border>
                            <Label Text="Кольцо 1" Style="{StaticResource SlotCaption}" />
                        </VerticalStackLayout>

                        <!-- Кольцо 2 -->
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Border Style="{StaticResource SlotBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding UnequipCommand}"
                                        CommandParameter="{Binding RingSlot2.Id}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                    <Image Source="icon_ring.png"
                                           WidthRequest="24" HeightRequest="24"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding RingSlot2.IsEquipped}" />
                                    <Label Text="{Binding RingSlot2.ItemName, TargetNullValue=''}"
                                           FontSize="9"
                                           TextColor="{StaticResource ColorTextPrimary}"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           MaxLines="2" LineBreakMode="WordWrap" />
                                    <Label Text="{Binding RingSlot2.Rarity}"
                                           Style="{StaticResource RarityLabel}"
                                           IsVisible="{Binding RingSlot2.IsEquipped}" />
                                </VerticalStackLayout>
                            </Border>
                            <Label Text="Кольцо 2" Style="{StaticResource SlotCaption}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- ═══ КОЛОНКА 2: Броня (Шлем / Броня / Ботинки сверху вниз) ═══ -->
                    <VerticalStackLayout Grid.Column="2" Spacing="8"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center">

                        <!-- Шлем -->
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Border Style="{StaticResource SlotBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding UnequipCommand}"
                                        CommandParameter="{Binding HelmetSlot.Id}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                    <Image Source="icon_helmet.png"
                                           WidthRequest="28" HeightRequest="28"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding HelmetSlot.IsEquipped}" />
                                    <Label Text="{Binding HelmetSlot.ItemName, TargetNullValue=''}"
                                           FontSize="9" TextColor="{StaticResource ColorTextPrimary}"
                                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                           MaxLines="2" LineBreakMode="WordWrap" />
                                    <Label Text="{Binding HelmetSlot.Rarity}"
                                           Style="{StaticResource RarityLabel}"
                                           IsVisible="{Binding HelmetSlot.IsEquipped}" />
                                </VerticalStackLayout>
                            </Border>
                            <Label Text="Шлем" Style="{StaticResource SlotCaption}" />
                        </VerticalStackLayout>

                        <!-- Броня -->
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Border Style="{StaticResource SlotBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding UnequipCommand}"
                                        CommandParameter="{Binding ArmorSlot.Id}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                    <Image Source="icon_armor_slot.png"
                                           WidthRequest="28" HeightRequest="28"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding ArmorSlot.IsEquipped}" />
                                    <Label Text="{Binding ArmorSlot.ItemName, TargetNullValue=''}"
                                           FontSize="9" TextColor="{StaticResource ColorTextPrimary}"
                                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                           MaxLines="2" LineBreakMode="WordWrap" />
                                    <Label Text="{Binding ArmorSlot.Rarity}"
                                           Style="{StaticResource RarityLabel}"
                                           IsVisible="{Binding ArmorSlot.IsEquipped}" />
                                </VerticalStackLayout>
                            </Border>
                            <Label Text="Броня" Style="{StaticResource SlotCaption}" />
                        </VerticalStackLayout>

                        <!-- Ботинки -->
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Border Style="{StaticResource SlotBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding UnequipCommand}"
                                        CommandParameter="{Binding BootsSlot.Id}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                    <Image Source="icon_boots.png"
                                           WidthRequest="28" HeightRequest="28"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding BootsSlot.IsEquipped}" />
                                    <Label Text="{Binding BootsSlot.ItemName, TargetNullValue=''}"
                                           FontSize="9" TextColor="{StaticResource ColorTextPrimary}"
                                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                           MaxLines="2" LineBreakMode="WordWrap" />
                                    <Label Text="{Binding BootsSlot.Rarity}"
                                           Style="{StaticResource RarityLabel}"
                                           IsVisible="{Binding BootsSlot.IsEquipped}" />
                                </VerticalStackLayout>
                            </Border>
                            <Label Text="Ботинки" Style="{StaticResource SlotCaption}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                </Grid>


                <!-- ══ Центральный кот ══ -->
                <Image Source="icon_cat.png"
                       WidthRequest="80"
                       HeightRequest="80"
                       HorizontalOptions="Center"
                       Opacity="0.3"
                       Margin="0,4,0,4" />

                <!-- ══ Оружие (3 слота) ══ -->
                <Label Text="⚔ Оружие" Style="{StaticResource SectionTitle}" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6" Margin="0,0,0,4">

                    <!-- Оружие 1 -->
                    <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                        <Border Style="{StaticResource SlotBorder}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding UnequipCommand}"
                                    CommandParameter="{Binding WeaponSlot1.Id}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Image Source="icon_weapon.png"
                                       WidthRequest="28" HeightRequest="28"
                                       HorizontalOptions="Center"
                                       IsVisible="{Binding WeaponSlot1.IsEquipped}" />
                                <Label Text="{Binding WeaponSlot1.ItemName, TargetNullValue=''}"
                                       FontSize="9"
                                       TextColor="{StaticResource ColorTextPrimary}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="2"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding WeaponSlot1.Rarity}"
                                       Style="{StaticResource RarityLabel}"
                                       IsVisible="{Binding WeaponSlot1.IsEquipped}" />
                            </VerticalStackLayout>
                        </Border>
                        <Label Text="Слот 1" Style="{StaticResource SlotCaption}" />
                    </VerticalStackLayout>

                    <!-- Оружие 2 -->
                    <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                        <Border Style="{StaticResource SlotBorder}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding UnequipCommand}"
                                    CommandParameter="{Binding WeaponSlot2.Id}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Image Source="icon_weapon.png"
                                       WidthRequest="28" HeightRequest="28"
                                       HorizontalOptions="Center"
                                       IsVisible="{Binding WeaponSlot2.IsEquipped}" />
                                <Label Text="{Binding WeaponSlot2.ItemName, TargetNullValue=''}"
                                       FontSize="9"
                                       TextColor="{StaticResource ColorTextPrimary}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="2"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding WeaponSlot2.Rarity}"
                                       Style="{StaticResource RarityLabel}"
                                       IsVisible="{Binding WeaponSlot2.IsEquipped}" />
                            </VerticalStackLayout>
                        </Border>
                        <Label Text="Слот 2" Style="{StaticResource SlotCaption}" />
                    </VerticalStackLayout>

                    <!-- Оружие 3 -->
                    <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                        <Border Style="{StaticResource SlotBorder}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding UnequipCommand}"
                                    CommandParameter="{Binding WeaponSlot3.Id}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Image Source="icon_weapon.png"
                                       WidthRequest="28" HeightRequest="28"
                                       HorizontalOptions="Center"
                                       IsVisible="{Binding WeaponSlot3.IsEquipped}" />
                                <Label Text="{Binding WeaponSlot3.ItemName, TargetNullValue=''}"
                                       FontSize="9"
                                       TextColor="{StaticResource ColorTextPrimary}"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="2"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding WeaponSlot3.Rarity}"
                                       Style="{StaticResource RarityLabel}"
                                       IsVisible="{Binding WeaponSlot3.IsEquipped}" />
                            </VerticalStackLayout>
                        </Border>
                        <Label Text="Слот 3" Style="{StaticResource SlotCaption}" />
                    </VerticalStackLayout>

                </Grid>

                <!-- ══ Инвентарь (32 ячейки) ══ -->
                <Label Text="🎒 Инвентарь" Style="{StaticResource SectionTitle}" />

                <!-- Сетка 32 ячеек: неэкипированные + пустые заглушки -->
                <CollectionView
                    x:Name="InventoryGrid"
                    ItemsSource="{Binding InventorySlots}"
                    SelectionMode="None"
                    HeightRequest="440">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="4" VerticalItemSpacing="6" HorizontalItemSpacing="6" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="inventory:InventoryItemDto">
                            <Border Style="{StaticResource InventorySlotBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EquipCommand}"
                                        CommandParameter="{Binding Id}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding ItemType}"
                                           FontSize="8"
                                           TextColor="{StaticResource ColorSecondary}"
                                           HorizontalOptions="Center" />
                                    <Label Text="{Binding ItemName}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource ColorTextPrimary}"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           MaxLines="2"
                                           LineBreakMode="WordWrap" />
                                    <Label Text="{Binding Rarity}"
                                           FontSize="8"
                                           TextColor="{StaticResource ColorHighlight}"
                                           HorizontalOptions="Center"
                                           IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBoolConverter}}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Лоадер / ошибка -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource ColorAccent}"
                                   HorizontalOptions="Center"
                                   Margin="0,12" />
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#FF6B6B"
                       IsVisible="{Binding HasError}"
                       HorizontalOptions="Center"
                       Margin="0,8" />

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
