<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="MobileApp.Views.Home.RoleStubPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B80D2231" Offset="0.20" />
            <GradientStop Color="#B864226A" Offset="0.50" />
            <GradientStop Color="#B8144161" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout
        VerticalOptions="Center"
        HorizontalOptions="Center"
        Spacing="20"
        Padding="32,0">

        <Label Text="🚫" FontSize="64" HorizontalOptions="Center" />

        <Label
            Text="Доступ закрыт"
            Style="{StaticResource TitleLabel}"
            HorizontalOptions="Center" />

        <Label
            Text="Это приложение предназначено только для игроков. Управление другими ролями доступно через веб-панель."
            Style="{StaticResource BodyLabel}"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center" />

        <Button
            Text="Выйти из аккаунта"
            Style="{StaticResource SecondaryButton}"
            Margin="0,16,0,0"
            Clicked="OnLogoutClicked" />

    </VerticalStackLayout>
</ContentPage>