<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MobileApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:auth="clr-namespace:MobileApp.Views.Auth"
    xmlns:home="clr-namespace:MobileApp.Views.Home"
    xmlns:character="clr-namespace:MobileApp.Views.Character"
    xmlns:skills="clr-namespace:MobileApp.Views.Skills"
    xmlns:inventory="clr-namespace:MobileApp.Views.Inventory"
    xmlns:trade="clr-namespace:MobileApp.Views.Trade"
    xmlns:friends="clr-namespace:MobileApp.Views.Friends"
    xmlns:support="clr-namespace:MobileApp.Views.Support"
    xmlns:profile="clr-namespace:MobileApp.Views.Profile">

    <!-- АВТОРИЗАЦИЯ -->
    <ShellContent
        x:Name="LoginShell"
        Route="LoginPage"
        ContentTemplate="{DataTemplate auth:LoginPage}"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        Route="RegisterPage"
        ContentTemplate="{DataTemplate auth:RegisterPage}"
        Shell.NavBarIsVisible="False" />

    <!-- HOME для Player -->
    <ShellContent
        x:Name="HomeShell"
        Route="HomePage"
        ContentTemplate="{DataTemplate home:HomePage}"
        Shell.NavBarIsVisible="False" />

    <!-- ЗАГЛУШКА для других ролей -->
    <ShellContent
        x:Name="StubShell"
        Route="RoleStubPage"
        ContentTemplate="{DataTemplate home:RoleStubPage}"
        Shell.NavBarIsVisible="False" />

</Shell>